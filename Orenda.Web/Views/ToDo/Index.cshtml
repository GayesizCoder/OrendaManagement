@model IEnumerable<Orenda.Web.Models.ToDo>
@{
    ViewData["Title"] = "Görev ve Proje Yönetimi";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="container-fluid pe-4 pb-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2">
        <div class="d-flex align-items-center">
            <div class="rounded-circle border border-warning me-3 bg-dark bg-opacity-50 d-flex justify-content-center align-items-center text-white fw-bold" style="width:50px; height:50px; font-size: 1.2rem; border-color: var(--bs-warning) !important;">
                <i class="bi bi-kanban"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0">Görev Panosu</h2>
                <small class="text-white-50">Tüm projeleri ve iş kalemlerini takip edin</small>
            </div>
        </div>
        
        <button class="btn btn-purple rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#yeniGorevModal">
            <i class="bi bi-plus-lg me-2"></i> Yeni Görev
        </button>
    </div>

    <!-- Kanban Grid -->
    <div class="row g-4">
        
        <!-- Yapılacaklar -->
        <div class="col-md-4">
            <div class="glass-panel p-3 h-100" style="background: rgba(255,193,7, 0.05); border-top: 3px solid var(--bs-warning);">
                <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                    <h5 class="fw-bold mb-0 text-warning">Yapılacaklar</h5>
                    <span class="badge bg-warning text-dark rounded-pill">@Model.Count(m => m.Durum == "Yapılacak" || m.Durum == "Yapilacak" || m.Durum == "Todo")</span>
                </div>
                
                <div class="task-list">
                    @foreach (var gorev in Model.Where(m => m.Durum == "Yapılacak" || m.Durum == "Yapilacak" || m.Durum == "Todo"))
                    {
                        <partial name="_TaskCardPartial" model="gorev" />
                    }
                </div>
            </div>
        </div>

        <!-- Devam Edenler -->
        <div class="col-md-4">
            <div class="glass-panel p-3 h-100" style="background: rgba(142, 68, 173, 0.05); border-top: 3px solid var(--accent-purple);">
                <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                    <h5 class="fw-bold mb-0" style="color: var(--accent-purple);">Devam Edenler</h5>
                    <span class="badge rounded-pill" style="background-color: var(--accent-purple); color: white;">@Model.Count(m => m.Durum.Contains("Devam"))</span>
                </div>
                
                <div class="task-list">
                    @foreach (var gorev in Model.Where(m => m.Durum.Contains("Devam")))
                    {
                        <partial name="_TaskCardPartial" model="gorev" />
                    }
                </div>
            </div>
        </div>

        <!-- Tamamlananlar -->
        <div class="col-md-4">
            <div class="glass-panel p-3 h-100" style="background: rgba(25, 135, 84, 0.05); border-top: 3px solid var(--bs-success);">
                <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                    <h5 class="fw-bold mb-0 text-success">Tamamlananlar</h5>
                    <span class="badge bg-success rounded-pill">@Model.Count(m => m.Durum.Contains("Tamamland") || m.Durum == "Bitti" || m.Durum == "Done")</span>
                </div>
                
                <div class="task-list">
                    @foreach (var gorev in Model.Where(m => m.Durum.Contains("Tamamland") || m.Durum == "Bitti" || m.Durum == "Done"))
                    {
                        <partial name="_TaskCardPartial" model="gorev" />
                    }
                </div>
            </div>
        </div>
        
    </div>

</div>

<!-- Yeni Görev Modal -->
<div class="modal fade" id="yeniGorevModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-panel" style="background: rgba(20, 20, 35, 0.95); border: 1px solid rgba(255,255,255,0.1);">
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title text-white fw-bold"><i class="bi bi-file-earmark-plus me-2 text-purple"></i> Yeni Görev Ata</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label text-white-50 small mb-1">Görev Başlığı <span class="text-danger">*</span></label>
                        <input type="text" name="Baslik" class="form-control bg-dark text-white border-secondary" required placeholder="Projeyi özetleyen kısa bir başlık...">
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white-50 small mb-1">Açıklama / Detaylar</label>
                        <textarea name="Aciklama" class="form-control bg-dark text-white border-secondary" rows="3" placeholder="Görev ile ilgili teknik notlar veya detaylar..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white-50 small mb-1">Atanacak Personel</label>
                        <select name="AtananCalisanID" class="form-select bg-dark text-white border-secondary" asp-items="ViewBag.Calisanlar">
                            <option value="">(İsteğe bağlı) Bir çalışan seçin...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-white-50 small mb-1">Atanacak Takım</label>
                        <select name="TakimID" class="form-select bg-dark text-white border-secondary" asp-items="ViewBag.Takimlar">
                            <option value="">(İsteğe bağlı) Bir takım seçin...</option>
                        </select>
                        <small class="text-info" style="font-size: 0.7rem;"><i class="bi bi-info-circle me-1"></i> Görevi bir kişiye, bir takıma veya her ikisine birden atayabilirsiniz.</small>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label text-white-50 small mb-1">Durumu</label>
                            <select name="Durum" class="form-select bg-dark text-white border-secondary">
                                <option value="Yapılacak">Yapılacak</option>
                                <option value="Devam Ediyor">Devam Ediyor</option>
                                <option value="Tamamlandı">Tamamlandı</option>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label text-white-50 small mb-1">Bitiş Tarihi / Deadline</label>
                            <input type="date" name="BitisTarihi" class="form-control bg-dark text-white border-secondary">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-purple rounded-pill px-4">Görevi Oluştur</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('create')) {
                var myModal = new bootstrap.Modal(document.getElementById('yeniGorevModal'));
                myModal.show();
            }
        });
    </script>
}