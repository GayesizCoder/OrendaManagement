@model IEnumerable<Orenda.Web.Models.ToDo>

@{
    ViewData["Title"] = "Görev Yönetimi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Orenda Görev Takip Sistemi</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-lg"></i> Yeni Görev Tanımla
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Görev Başlığı</th>
                        <th>Sorumlu Personel</th>
                        <th>Durum</th>
                        <th>Bitiş Tarihi</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.GorevNo</td>
                            <td>
                                <strong>@item.Baslik</strong><br />
                                <small class="text-muted">@item.Aciklama</small>
                            </td>
                            <td>
                                @(item.AtananKisi != null ? $"{item.AtananKisi.Ad} {item.AtananKisi.Soyad}" : "Atanmamış")
                            </td>
                            <td>
                                @if (item.Durum == "Tamamlandi")
                                {
                                    <span class="badge bg-success">Tamamlandı</span>
                                }
                                else if (item.Durum == "Yapiliyor")
                                {
                                    <span class="badge bg-primary">Yapılıyor</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Beklemede</span>
                                }
                            </td>
                            <td>@item.BitisTarihi?.ToString("dd.MM.yyyy")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.GorevNo" class="btn btn-sm btn-outline-primary">Düzenle</a>
                                <a asp-action="Details" asp-route-id="@item.GorevNo" class="btn btn-sm btn-outline-info">Detay</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>