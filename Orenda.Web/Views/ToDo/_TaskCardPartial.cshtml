@model Orenda.Web.Models.ToDo
@{
    bool isAdmin = User.IsInRole("Admin");
    
    // Status color logic (fallback)
    string statusBadgeClass = "bg-warning text-dark";
    if (Model.Durum != null)
    {
        if (Model.Durum.Contains("Devam")) statusBadgeClass = "bg-purple text-white";
        else if (Model.Durum.Contains("Tamamland") || Model.Durum == "Bitti" || Model.Durum == "Done") statusBadgeClass = "bg-success text-white";
    }
}

<div class="card bg-dark bg-opacity-50 border-secondary border-opacity-25 mb-3 shadow-sm task-card transition-hover">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="card-title text-white fw-bold mb-0">@Model.Baslik</h6>
            
            @if(isAdmin)
            {
                <form asp-action="Delete" asp-route-id="@Model.GorevNo" method="post" class="d-inline" onsubmit="return confirm('Bu görevi silmek istediğinize emin misiniz?');">
                    <button type="submit" class="btn btn-sm btn-link text-danger p-0 m-0 text-decoration-none">
                        <i class="bi bi-trash"></i>
                    </button>
                </form>
            }
        </div>
        
        <p class="card-text text-white-50 small mb-3">
            @(string.IsNullOrEmpty(Model.Aciklama) ? "Açıklama girilmemiş." : (Model.Aciklama.Length > 80 ? Model.Aciklama.Substring(0, 80) + "..." : Model.Aciklama))
        </p>
        
        <div class="d-flex justify-content-between align-items-center mb-0">
            <div class="d-flex align-items-center">
                <div class="rounded-circle border border-secondary text-white-50 bg-dark d-flex justify-content-center align-items-center me-2" style="width: 25px; height: 25px; font-size: 0.7rem;" title="Atanan: @(Model.AtananKisi?.Ad ?? "Bilinmiyor")">
                    @(Model.AtananKisi?.Ad?.Substring(0,1) ?? "?")
                </div>
                <small class="text-white-50" style="font-size: 0.75rem;">
                    @if(Model.BitisTarihi.HasValue)
                    {
                        var isLate = Model.BitisTarihi.Value < DateTime.Now && !Model.Durum.Contains("Tamamland");
                        <span class="@(isLate ? "text-danger" : "")">
                            <i class="bi bi-clock"></i> @Model.BitisTarihi.Value.ToString("dd MMM")
                        </span>
                    }
                </small>
            </div>
            
            <!-- Durum Güncelleme Butonu -->
            <div class="dropdown">
                <button class="btn btn-sm badge @statusBadgeClass dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="border: none;">
                    @Model.Durum
                </button>
                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow-sm" style="font-size: 0.85rem; background: rgba(30, 30, 40, 0.95); border: 1px solid rgba(255,255,255,0.1);">
                    <li>
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.GorevNo" />
                            <input type="hidden" name="yeniDurum" value="Yapılacak" />
                            <button type="submit" class="dropdown-item py-2 text-warning"><i class="bi bi-circle me-2"></i>Yapılacak</button>
                        </form>
                    </li>
                    <li>
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.GorevNo" />
                            <input type="hidden" name="yeniDurum" value="Devam Ediyor" />
                            <button type="submit" class="dropdown-item py-2 text-purple"><i class="bi bi-play-circle me-2"></i>Devam Ediyor</button>
                        </form>
                    </li>
                    <li>
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.GorevNo" />
                            <input type="hidden" name="yeniDurum" value="Tamamlandı" />
                            <button type="submit" class="dropdown-item py-2 text-success"><i class="bi bi-check-circle me-2"></i>Tamamlandı</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .task-card { cursor: move; }
    .transition-hover { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .transition-hover:hover { 
        transform: translateY(-3px); 
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.3)!important;
        border-color: rgba(255,255,255,0.2) !important;
    }
    .text-purple { color: var(--accent-purple) !important; }
    .bg-purple { background-color: var(--accent-purple) !important; color: white !important;}
</style>
