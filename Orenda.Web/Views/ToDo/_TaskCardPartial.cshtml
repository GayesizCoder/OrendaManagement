@model Orenda.Web.Models.ToDo
@using System.Security.Claims
@{
    bool isAdmin = User.IsInRole("Admin");
    var userIdClaim = User.FindFirst("CalisanID")?.Value ?? User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    int currentUserId = userIdClaim != null ? int.Parse(userIdClaim) : 0;
    
    // Check if user is in the team this task is assigned to
    // Note: This requires the Takim object to be included in the query (which I did in the controller)
    bool isInAssignedTeam = Model.TakimID.HasValue && Model.Takim != null && Model.Takim.Uyeler != null && Model.Takim.Uyeler.Any(u => u.CalisanID == currentUserId);
    // Alternative check if Uyeler is not loaded: we might need to rely on the controller logic for button visibility, 
    // but for display, we just need the Team name.
    
    bool isManager = isAdmin;
    bool isAssignee = Model.AtananCalisanID == currentUserId || isInAssignedTeam;

    // Status color logic (fallback)
    string statusBadgeClass = "bg-warning text-dark";
    if (Model.Durum != null)
    {
        if (Model.Durum.Contains("Devam")) statusBadgeClass = "bg-purple text-white";
        else if (Model.Durum.Contains("Tamamland") || Model.Durum == "Bitti" || Model.Durum == "Done") statusBadgeClass = "bg-success text-white";
    }
    
    // Approval styling
    string onayColor = Model.OnayDurumu switch {
        "Onay Bekliyor" => "bg-warning text-dark",
        "Onaylandı" => "bg-success text-white",
        "Reddedildi" => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };
}

<div id="task-card-container-@Model.GorevNo" class="task-card-wrapper">
<div class="card bg-dark bg-opacity-50 border-secondary border-opacity-25 mb-3 shadow-sm task-card transition-hover">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <h6 class="card-title text-white fw-bold mb-1">@Model.Baslik</h6>
                <div class="d-flex flex-wrap gap-1 mb-1">
                    <span class="badge @onayColor" style="font-size: 0.65rem;">
                        @if(Model.OnayDurumu == "Onay Bekliyor") { <i class="bi bi-hourglass-split"></i> }
                        else if(Model.OnayDurumu == "Onaylandı") { <i class="bi bi-check-circle-fill"></i> }
                        else if(Model.OnayDurumu == "Reddedildi") { <i class="bi bi-x-circle-fill"></i> }
                        @Model.OnayDurumu
                    </span>
                    @if (Model.TakimID.HasValue)
                    {
                        <span class="badge bg-purple text-white" style="font-size: 0.65rem;" title="Takım Görevi">
                            <i class="bi bi-people-fill me-1"></i> @(Model.Takim?.Ad ?? "Takım")
                        </span>
                    }
                    @if (Model.AtananCalisanID.HasValue)
                    {
                         <span class="badge bg-secondary text-white-50" style="font-size: 0.65rem;" title="Bireysel Görev">
                            <i class="bi bi-person-fill me-1"></i> @(Model.AtananKisi?.Ad ?? "Atandı")
                         </span>
                    }
                </div>
            </div>
            
            @if(isAdmin)
            {
                <form asp-action="Delete" asp-route-id="@Model.GorevNo" method="post" class="d-inline" onsubmit="return confirm('Bu görevi silmek istediğinize emin misiniz?');">
                    <button type="submit" class="btn btn-sm btn-link text-danger p-0 m-0 text-decoration-none">
                        <i class="bi bi-trash"></i>
                    </button>
                </form>
            }
        </div>
        
        @if(Model.OnayDurumu == "Reddedildi" && !string.IsNullOrEmpty(Model.OnayNotu))
        {
            <div class="alert alert-danger px-2 py-1 small rounded border border-danger mb-2" style="font-size: 0.75rem;">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> <strong>Yönetici Notu:</strong> @Model.OnayNotu
            </div>
        }

        <p class="card-text text-white-50 small mb-2">
            @(string.IsNullOrEmpty(Model.Aciklama) ? "Açıklama girilmemiş." : (Model.Aciklama.Length > 80 ? Model.Aciklama.Substring(0, 80) + "..." : Model.Aciklama))
        </p>

        <!-- SUB TASKS VE PROGRESS BAR -->
        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="text-white-50" style="font-size: 0.7rem;">İlerleme</small>
                <small class="text-white fw-bold" style="font-size: 0.75rem;">%@Model.TamamlanmaOrani</small>
            </div>
            <div class="progress mb-2" style="height: 5px; background: rgba(255,255,255,0.1);">
                <div class="progress-bar" style="width: @Model.TamamlanmaOrani.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%; background: var(--accent-purple);"></div>
            </div>
            
            <button class="btn btn-sm text-white-50 bg-dark border-secondary w-100 pb-1 pt-1" type="button" data-bs-toggle="collapse" data-bs-target="#subtasks-@Model.GorevNo" style="font-size: 0.75rem;">
                İş Bölümleri (@(Model.Adimlar?.Count(a => a.TamamlandiMi) ?? 0)/@(Model.Adimlar?.Count ?? 0)) <i class="bi bi-chevron-down ms-1"></i>
            </button>
            <div class="collapse mt-2" id="subtasks-@Model.GorevNo">
                <div class="card card-body bg-dark border-secondary p-2 shadow-sm">
                    @if(Model.Adimlar != null && Model.Adimlar.Any())
                    {
                        foreach(var adim in Model.Adimlar.OrderBy(a => a.TamamlandiMi))
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2 border-bottom border-light border-opacity-10 pb-1">
                                <div class="form-check m-0 p-0 d-flex align-items-center">
                                    <form asp-action="ToggleSubTask" method="post" class="d-inline m-0 p-0 ajax-form">
                                        <input type="hidden" name="adimId" value="@adim.AdimID" />
                                        <input type="hidden" name="completed" value="@((!adim.TamamlandiMi).ToString().ToLower())" />
                                        <input class="form-check-input ms-0 me-2 mt-0 subtask-check" style="cursor: pointer;" type="checkbox" @(adim.TamamlandiMi ? "checked" : "") id="adim-@adim.AdimID">
                                        <label class="form-check-label text-white @(adim.TamamlandiMi ? "text-decoration-line-through text-white-50" : "")" style="font-size: 0.75rem; cursor: pointer;" for="adim-@adim.AdimID">
                                            @adim.Baslik
                                        </label>
                                    </form>
                                </div>
                                @if(adim.AgirlikYuzdesi.HasValue)
                                {
                                    <span class="badge bg-secondary" style="font-size: 0.65rem;">%@adim.AgirlikYuzdesi</span>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <small class="text-white-50 d-block mb-2 text-center" style="font-size: 0.7rem;">Henüz iş bölümü eklenmemiş.</small>
                    }
                    
                    @if(Model.OnayDurumu == "Planlanıyor" || Model.OnayDurumu == "Reddedildi")
                    {
                        @if(isAssignee || isAdmin)
                        {
                            <form asp-action="AddSubTask" method="post" class="mt-2 mb-2 bg-black bg-opacity-25 p-2 rounded ajax-form">
                                 <input type="hidden" name="gorevNo" value="@Model.GorevNo" />
                                 <div class="mb-1">
                                     <input type="text" name="adimBaslik" class="form-control form-control-sm bg-dark text-white border-secondary" placeholder="Örn: Veritabanı tablolarının açılması..." required style="font-size: 0.75rem;" />
                                 </div>
                                 <div class="input-group input-group-sm">
                                     <input type="number" name="agirlikYuzdesi" class="form-control bg-dark text-white border-secondary" placeholder="% Ağırlık (Opsiyonel)" min="1" max="100" style="font-size: 0.75rem;" />
                                     <button class="btn btn-purple" type="submit" style="font-size: 0.75rem;"><i class="bi bi-plus"></i> Ekle</button>
                                 </div>
                            </form>
                            
                            <form asp-action="SubmitForApproval" method="post" class="mt-2 text-end">
                                <input type="hidden" name="id" value="@Model.GorevNo" />
                                <button type="submit" class="btn btn-sm btn-outline-warning w-100" style="font-size: 0.75rem;">
                                    <i class="bi bi-send me-1"></i> Planı Onaya Gönder
                                </button>
                            </form>
                        }
                    }
                    else if (Model.OnayDurumu == "Onay Bekliyor" && isManager)
                    {
                        <div class="mt-2 bg-black bg-opacity-25 p-2 rounded border border-warning border-opacity-50">
                            <small class="text-warning d-block mb-2"><i class="bi bi-check2-circle"></i> Onay İşlemi</small>
                            <form asp-action="ReviewPlan" method="post">
                                <input type="hidden" name="id" value="@Model.GorevNo" />
                                <textarea name="onayNotu" class="form-control bg-dark text-white border-secondary mb-2" rows="2" placeholder="Reddedersiniz nedenini yazın..." style="font-size: 0.75rem;"></textarea>
                                <div class="d-flex gap-2">
                                    <button type="submit" name="karar" value="Onayla" class="btn btn-sm btn-success flex-grow-1" style="font-size: 0.75rem;"><i class="bi bi-check"></i> Onayla</button>
                                    <button type="submit" name="karar" value="Reddet" class="btn btn-sm btn-danger flex-grow-1" style="font-size: 0.75rem;"><i class="bi bi-x"></i> Reddet</button>
                                </div>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
        <!-- SUB TASKS VE PROGRESS BAR BITIS -->
        
        <div class="d-flex justify-content-between align-items-center mb-0">
            <div class="d-flex align-items-center">
                <div class="rounded-circle border border-secondary text-white-50 bg-dark d-flex justify-content-center align-items-center me-2" style="width: 25px; height: 25px; font-size: 0.7rem;" title="Atanan: @(Model.AtananKisi?.Ad ?? "Bilinmiyor")">
                    @(Model.AtananKisi?.Ad?.Substring(0,1) ?? "?")
                </div>
                <small class="text-white-50" style="font-size: 0.75rem;">
                    @if(Model.BitisTarihi.HasValue)
                    {
                        var isLate = Model.BitisTarihi < DateTime.Now && !Model.Durum.Contains("Tamamland");
                        <span class="@(isLate ? "text-danger" : "")">
                            <i class="bi bi-clock"></i> @Model.BitisTarihi.Value.ToString("dd MMM")
                        </span>
                    }
                </small>
            </div>
            
            <!-- Durum Güncelleme Butonu -->
            <div class="dropdown">
                <button class="btn btn-sm badge @statusBadgeClass dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" aria-expanded="false" style="border: none;">
                    @Model.Durum
                </button>
                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow-sm dropdown-menu-custom" style="font-size: 0.85rem;">
                    <li>
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.GorevNo" />
                            <input type="hidden" name="yeniDurum" value="Yapılacak" />
                            <button type="submit" class="dropdown-item py-2 text-white"><i class="bi bi-circle me-2 text-warning"></i>Yapılacak</button>
                        </form>
                    </li>
                    <li>
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.GorevNo" />
                            <input type="hidden" name="yeniDurum" value="Devam Ediyor" />
                            <button type="submit" class="dropdown-item py-2 text-white"><i class="bi bi-play-circle me-2 text-purple"></i>Devam Ediyor</button>
                        </form>
                    </li>
                    <li>
                        <form asp-action="UpdateStatus" method="post">
                            <input type="hidden" name="id" value="@Model.GorevNo" />
                            <input type="hidden" name="yeniDurum" value="Tamamlandı" />
                            <button type="submit" class="dropdown-item py-2 text-white"><i class="bi bi-check-circle me-2 text-success"></i>Tamamlandı</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
</div>
