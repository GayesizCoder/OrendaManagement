<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orenda Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar shadow-sm d-flex flex-column p-4">
            <h3 class="fw-bold mb-5">Orenda</h3>
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item mb-3">
                    <a href="#" class="nav-link active rounded-pill bg-dark">
                        <i class="bi bi-grid-fill me-2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item mb-3">
                    <a href="#" class="nav-link text-dark">
                        <i class="bi bi-kanban me-2"></i> Tasks
                    </a>
                </li>
                <li class="nav-item mb-3">
                    <a href="#" class="nav-link text-dark">
                        <i class="bi bi-people me-2"></i> Team
                    </a>
                </li>
                <li class="nav-item mb-3">
                    <a href="#" class="nav-link text-dark">
                        <i class="bi bi-broadcast me-2"></i> RFID Logs
                    </a>
                </li>
            </ul>
            <div class="user-profile mt-auto d-flex align-items-center">
                <img src="https://via.placeholder.com/40" class="rounded-circle me-2">
                <div>
                    <strong class="d-block">Kullanıcı</strong>
                    <small class="text-muted">Admin</small>
                </div>
            </div>
        </nav>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="ToDo" asp-action="Index">Görevler</a>
        </li>
        <main role="main" class="flex-grow-1 p-5">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>