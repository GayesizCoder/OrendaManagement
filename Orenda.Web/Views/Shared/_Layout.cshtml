<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orenda Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        /* Aktif menü öğesi için senin mor tonun */
        .bg-purple.active {
            background: var(--accent-purple) !important;
            box-shadow: 0 4px 15px rgba(108, 92, 231, 0.4);
            border-radius: 10px;
        }

        .nav-link {
            border-radius: 10px;
            margin-bottom: 5px;
            transition: all 0.3s ease;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateX(5px);
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar with Glassmorphism -->
        <nav class="sidebar glass-panel m-3" style="min-width: 260px; height: calc(100vh - 2rem); position: fixed; z-index: 1000;">
            <div class="p-4 d-flex flex-column h-100">
                <div class="d-flex align-items-center mb-5">
                    <div class="bg-purple text-white rounded d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px; background: var(--accent-purple); box-shadow: 0 4px 15px rgba(108, 92, 231, 0.4);">
                        <i class="bi bi-layers-fill"></i>
                    </div>
                    <h4 class="fw-bold mb-0 text-white" style="letter-spacing: 1px;">Orenda</h4>
                </div>

                <ul class="nav nav-pills flex-column mb-auto">
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="Index"
                           class="nav-link text-white @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "bg-purple active" : "")">
                            <i class="bi bi-grid-fill me-2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="ToDo" asp-action="Index"
                           class="nav-link text-white @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ToDo" ? "bg-purple active" : "")">
                            <i class="bi bi-kanban me-2"></i> Görevler
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a asp-controller="Team" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Team" ? "active-custom" : "")">
                                <i class="bi bi-people me-2"></i> Ekip Yönetimi
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Log" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Log" ? "active-custom" : "")">
                                <i class="bi bi-journal-text me-2"></i> Sistem Logları
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a href="#" class="nav-link text-white-50">
                                <i class="bi bi-people me-2"></i> Takımım
                            </a>
                        </li>
                    }
                </ul>

                <div class="user-profile mt-auto pt-3 border-top border-secondary d-flex align-items-center">
                    <img src="https://via.placeholder.com/40" class="rounded-circle me-3 border border-2" style="border-color: var(--accent-purple) !important;">
                    <div class="flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <strong class="d-block text-white">@User.Identity.Name</strong>
                            <small class="text-white-50">@(User.IsInRole("Admin") ? "Yönetici" : "Çalışan")</small>
                            <a asp-controller="Account" asp-action="Logout" class="d-block text-danger small mt-1 text-decoration-none">
                                <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm w-100">Giriş Yap</a>
                        }
                    </div>
                </div>
            </div>
        </nav>

        <main role="main" class="flex-grow-1" style="margin-left: 280px; min-height: 100vh;">
            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>