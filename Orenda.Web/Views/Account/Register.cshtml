@model Orenda.Web.Models.Kullanici

@{
    Layout = null; // Üst menü ve alt barın görünmemesi için
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orenda - Kayıt Ol</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        /* Ana Arka Plan */
        body {
            background-color: #1a1a2e;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
        }

        /* Kayıt Paneli (İki Bölmeli) */
        .login-container {
            display: flex;
            background: #242443;
            border-radius: 30px;
            overflow: hidden;
            max-width: 1000px;
            width: 90%;
            min-height: 650px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        /* Sol Taraf (Görsel Alanı - Login ile aynı görsel) */
        .login-image {
            flex: 1;
            background: linear-gradient(rgba(108, 92, 231, 0.3), rgba(26, 26, 46, 0.8)), url('https://images.unsplash.com/photo-1659698328281-53fc377cebcb?q=80&w=1932&auto=format&fit=crop') center;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* Sağ Taraf (Form Alanı) */
        .login-form-side {
            flex: 1;
            padding: 40px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #242443;
        }

        /* Yazı Kutuları (Input) Ayarları */
        .form-control {
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid #3f3f6b !important;
            color: white !important;
            border-radius: 12px;
            padding: 12px;
            transition: all 0.3s;
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.5) !important;
        }

        .form-control:focus {
            background: rgba(255, 255, 255, 0.1) !important;
            border-color: #6c5ce7 !important;
            box-shadow: 0 0 15px rgba(108, 92, 231, 0.3);
            outline: none;
        }

        /* Mor Buton */
        .btn-purple {
            background: #6c5ce7;
            color: white;
            border-radius: 12px;
            padding: 12px;
            font-weight: bold;
            border: none;
            transition: 0.3s;
        }

        .btn-purple:hover {
            background: #5849cf;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);
        }

        .text-purple {
            color: #a29bfe;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-image">
            <h3 class="fw-bold">ORENDA</h3>
            <div>
                <h1 class="fw-bold">Aramıza Katıl.</h1>
                <p class="opacity-75 fs-5">Kendi dünyanı yönetmeye buradan başla.</p>
            </div>
            <div class="d-flex gap-2">
                <div style="width: 15px; height: 4px; background: rgba(255,255,255,0.3); border-radius: 2px;"></div>
                <div style="width: 30px; height: 4px; background: white; border-radius: 2px;"></div>
            </div>
        </div>

        <div class="login-form-side">
            <h2 class="fw-bold mb-2">Hesap Oluştur</h2>
            <p class="text-secondary small mb-4">Lütfen bilgilerinizi eksiksiz doldurun.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small border-0 bg-danger bg-opacity-25 text-white mb-3">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Account" asp-action="Register" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <input type="text" asp-for="Ad" class="form-control" placeholder="Ad" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <input type="text" asp-for="Soyad" class="form-control" placeholder="Soyad" required>
                    </div>
                </div>

                <div class="mb-3">
                    <input type="email" asp-for="Eposta" class="form-control" placeholder="E-posta Adresi (İsteğe bağlı)">
                </div>

                <div class="mb-3">
                    <input type="text" asp-for="KullaniciAdi" class="form-control" placeholder="Kullanıcı Adı" required>
                </div>

                <div class="mb-4">
                    <input type="password" asp-for="Sifre" class="form-control" placeholder="Şifre" required>
                </div>

                <button type="submit" class="btn btn-purple w-100 mb-4">Kaydı Tamamla</button>

                <div class="text-center">
                    <p class="small">
                        Zaten bir hesabın var mı?
                        <a asp-controller="Account" asp-action="Login" class="text-purple fw-bold text-decoration-none">Giriş Yap</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</body>
</html>