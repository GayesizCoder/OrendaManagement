@model Orenda.Web.Models.Kullanici

@{
    Layout = null; // Üst menü ve alt barın görünmemesi için
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orenda - Kayıt Ol</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Kayıt Paneli (İki Bölmeli) */
        .login-container {
            display: flex;
            overflow: hidden;
            max-width: 1250px; /* Genişletildi */
            width: 95%;
            min-height: 750px; /* Fazla input için yükseklik */
            margin: auto;
            margin-top: 5vh;
        }

        /* Sol Taraf (Görsel Alanı - Login ile aynı görsel) */
        .login-image {
            flex: 0 0 45%; 
            background: linear-gradient(rgba(108, 92, 231, 0.4), var(--glass-bg)), url('https://images.unsplash.com/photo-1659698328281-53fc377cebcb?q=80&w=1932&auto=format&fit=crop') center;
            background-size: cover;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* Sağ Taraf (Form Alanı) */
        .login-form-side {
            flex: 1;
            padding: 80px 100px; /* İç boşlukları ciddi şekilde artırdım */
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* Form elemanlarının boyutunu daha orantılı hale getirmek için yeni sınıflar */
        .login-form-side h2 {
            font-size: 2.5rem; /* Başlık büyüdü */
            margin-bottom: 0.5rem;
        }
        
        .login-form-side p {
            font-size: 1.1rem; /* Açıklayıcı metin büyüdü */
            margin-bottom: 2rem !important;
        }

        .text-purple {
            color: var(--accent-purple);
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="login-container glass-panel">
        <div class="login-image border-end border-secondary border-opacity-25">
            <h3 class="fw-bold">ORENDA</h3>
            <div>
                <h1 class="fw-bold">Aramıza Katıl.</h1>
                <p class="opacity-75 fs-5">Kendi dünyanı yönetmeye buradan başla.</p>
            </div>
            <div class="d-flex gap-2">
                <div style="width: 15px; height: 4px; background: rgba(255,255,255,0.3); border-radius: 2px;"></div>
                <div style="width: 30px; height: 4px; background: white; border-radius: 2px;"></div>
            </div>
        </div>

        <div class="login-form-side">
            <h2 class="fw-bold mb-2">Hesap Oluştur</h2>
            <p class="text-secondary small mb-4 text-opacity-75" style="color: var(--text-muted) !important;">Lütfen bilgilerinizi eksiksiz doldurun.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small border-0 bg-danger bg-opacity-25 text-white mb-3">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Account" asp-action="Register" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <input type="text" asp-for="Ad" class="form-control glass-input w-100" placeholder="Ad" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <input type="text" asp-for="Soyad" class="form-control glass-input w-100" placeholder="Soyad" required>
                    </div>
                </div>

                <div class="mb-3">
                    <input type="email" asp-for="Eposta" class="form-control glass-input w-100" placeholder="E-posta Adresi (İsteğe bağlı)">
                </div>

                <div class="mb-3">
                    <input type="text" asp-for="KullaniciAdi" class="form-control glass-input w-100" placeholder="Kullanıcı Adı" required>
                </div>

                <div class="mb-4">
                    <input type="password" asp-for="Sifre" class="form-control glass-input w-100" placeholder="Şifre" required>
                </div>

                <button type="submit" class="btn btn-glass-primary w-100 mb-4 py-3">Kaydı Tamamla</button>

                <div class="text-center">
                    <p class="small">
                        Zaten bir hesabın var mı?
                        <a asp-controller="Account" asp-action="Login" class="text-purple fw-bold text-decoration-none">Giriş Yap</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</body>
</html>