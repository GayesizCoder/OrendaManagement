@{
    Layout = null; // Üst menü ve alt barın görünmemesi için
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orenda - Giriş Yap</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Kayıt Paneli (İki Bölmeli) */
        .login-container {
            display: flex;
            overflow: hidden;
            max-width: 1250px; /* Genişletildi */
            width: 95%; /* Biraz daha esnek yapıldı */
            min-height: 700px; /* Yükseklik artırıldı */
            margin: auto;
            margin-top: 5vh;
        }

        /* Sol Taraf (Görsel Alanı) */
        .login-image {
            flex: 0 0 45%; /* Görsel genişliği biraz daha dar, form genişliği artacak */
            background: linear-gradient(rgba(108, 92, 231, 0.4), var(--glass-bg)), url('https://images.unsplash.com/photo-1659698328281-53fc377cebcb?q=80&w=1932&auto=format&fit=crop') center;
            background-size: cover;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* Sağ Taraf (Form Alanı) */
        .login-form-side {
            flex: 1;
            padding: 80px 100px; /* İç boşlukları ciddi şekilde artırdım */
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* Form elemanlarının boyutunu daha orantılı hale getirmek için yeni sınıflar */
        .login-form-side h2 {
            font-size: 2.5rem; /* Başlık büyüdü */
            margin-bottom: 0.5rem;
        }
        
        .login-form-side p {
            font-size: 1.1rem; /* Açıklayıcı metin büyüdü */
            margin-bottom: 2rem !important;
        }

        .text-purple {
            color: var(--accent-purple);
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="login-container glass-panel">
        <div class="login-image border-end border-secondary border-opacity-25">
            <h3 class="fw-bold">ORENDA</h3>
            <div>
                <h1 class="fw-bold">Geleceği Yönetin.</h1>
                <p class="opacity-75 fs-5">Anları Yakalayın, Hafızalar Oluşturun.</p>
            </div>
            <div class="d-flex gap-2">
                <div style="width: 30px; height: 4px; background: white; border-radius: 2px;"></div>
                <div style="width: 15px; height: 4px; background: rgba(255,255,255,0.3); border-radius: 2px;"></div>
            </div>
        </div>

        <div class="login-form-side">
            <h2 class="fw-bold mb-2">Giriş Yap</h2>

            <div class="mt-2 mb-3">
                <p class="small">
                    Henüz bir hesabınız yok mu?
                    <a asp-controller="Account" asp-action="Register" class="text-primary fw-bold text-decoration-none">Kayıt olmak için tıkla</a>
                </p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small border-0 bg-danger bg-opacity-25 text-white">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="mb-3">
                    <input type="text" name="kullaniciAdi" class="form-control glass-input w-100" placeholder="Kullanıcı Adı veya E-posta" required>
                </div>
                <div class="mb-4">
                    <input type="password" name="sifre" class="form-control glass-input w-100" placeholder="Şifre" required>
                </div>

                <div class="d-flex justify-content-between mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember" style="background-color: transparent; border-color: var(--glass-border);">
                        <label class="form-check-label text-secondary small" for="remember">Beni Hatırla</label>
                    </div>
                    <a href="#" class="text-purple small text-decoration-none">Şifremi Unuttum</a>
                </div>

                <button type="submit" class="btn btn-glass-primary w-100 py-3">Giriş Yap</button>
            </form>
        </div>
    </div>
</body>
</html>