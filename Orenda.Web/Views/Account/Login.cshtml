@{
    Layout = null; // Üst menü ve alt barın görünmemesi için
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orenda - Giriş Yap</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        /* Ana Arka Plan */
        body {
            background-color: #1a1a2e;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
        }

        /* Giriş Paneli (İki Bölmeli) */
        .login-container {
            display: flex;
            background: #242443;
            border-radius: 30px;
            overflow: hidden;
            max-width: 1000px;
            width: 90%;
            min-height: 600px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        /* Sol Taraf (Görsel Alanı) */
        .login-image {
            flex: 1;
            background: linear-gradient(rgba(108, 92, 231, 0.3), rgba(26, 26, 46, 0.8)), url('https://images.unsplash.com/photo-1659698328281-53fc377cebcb?q=80&w=1932&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D') center;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* Sağ Taraf (Form Alanı) */
        .login-form-side {
            flex: 1;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: #242443;
        }

        /* Yazı Kutuları (Input) Ayarları */
        .form-control {
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid #3f3f6b !important;
            color: white !important; /* Yazılan yazı beyaz */
            border-radius: 12px;
            padding: 15px;
            transition: all 0.3s;
        }

            /* Placeholder (Tıklanmadan önceki yazı) Beyazlatma */
            .form-control::placeholder {
                color: rgba(255, 255, 255, 0.7) !important; /* Yazılar bembeyaz ve net */
                font-weight: 400;
            }

            .form-control:focus {
                background: rgba(255, 255, 255, 0.1) !important;
                border-color: #6c5ce7 !important;
                box-shadow: 0 0 15px rgba(108, 92, 231, 0.3);
                outline: none;
            }

        /* Mor Buton */
        .btn-purple {
            background: #6c5ce7;
            color: white;
            border-radius: 12px;
            padding: 15px;
            font-weight: bold;
            border: none;
            transition: 0.3s;
        }

            .btn-purple:hover {
                background: #5849cf;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);
            }

        .text-purple {
            color: #a29bfe;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-image">
            <h3 class="fw-bold">ORENDA</h3>
            <div>
                <h1 class="fw-bold">Geleceği Yönetin.</h1>
                <p class="opacity-75 fs-5">Anları Yakalayın, Hafızalar Oluşturun.</p>
            </div>
            <div class="d-flex gap-2">
                <div style="width: 30px; h: 4px; background: white; border-radius: 2px;"></div>
                <div style="width: 15px; h: 4px; background: rgba(255,255,255,0.3); border-radius: 2px;"></div>
            </div>
        </div>

        <div class="login-form-side">
            <h2 class="fw-bold mb-2">Giriş Yap</h2>
            <p class="text-secondary mb-4">Hesabınız yok mu? <a href="#" class="text-purple text-decoration-none fw-bold">Kayıt Ol</a></p>

            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="mb-3">
                    <input type="text" name="kullaniciAdi" class="form-control" placeholder="Kullanıcı Adı" required>
                </div>
                <div class="mb-4">
                    <input type="password" name="sifre" class="form-control" placeholder="Şifre" required>
                </div>

                <div class="d-flex justify-content-between mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="remember">
                        <label class="form-check-label text-secondary small" for="remember">Beni Hatırla</label>
                    </div>
                    <a href="#" class="text-purple small text-decoration-none">Şifremi Unuttum</a>
                </div>

                <button type="submit" class="btn btn-purple w-100 mb-4">Giriş Yap</button>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 small border-0 bg-danger bg-opacity-25 text-white">
                        @ViewBag.Error
                    </div>
                }
            </form>
        </div>
    </div>
</body>
</html>