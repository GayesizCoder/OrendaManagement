## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.csproj.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Xx]64/
[Xx]86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Vv]isualStudioToolsSDK/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/lib/

# Visual Studio Code
.vscode/

# Database files
*.db
*.db-shm
*.db-wal

# Sensitive files
appsettings.json
!appsettings.Example.json
!appsettings.Development.json

# Published files
[Pp]ublish/

# Logs
*.log
build_err.txt
build_errors.txt
build_output.txt
db_error.log
errors.txt
errors_cmd.txt
run_temp.log
verbose_update.txt
verbose_utf8.txt
